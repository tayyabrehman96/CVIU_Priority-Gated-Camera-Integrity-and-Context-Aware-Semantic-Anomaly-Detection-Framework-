# Environment and tooling
.env
# Local overrides (copy from config.example.py); not committed
config.py
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.vscode/
.idea/

# Large / generated assets (reproduce via scripts; see README)
*.pt
*.pth
*.onnx
videos/*.mp4
videos/*.avi
videos/*.mkv
videos/*.mov
simulations/

# Figures (regenerate with generate_*.py); PNG/JPEG not committed
Images/*
!Images/README.md
!Images/.gitkeep
/fig9_sota_*.png

# Experiment outputs: CSV results are tracked; other files under reports/ stay untracked
reports/*
!reports/.gitkeep
!reports/*.csv

# Legacy demo paths (not used in research release)
exports/
calibration_templates/
reference_templates/
